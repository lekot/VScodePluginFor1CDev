{
  "name": "1c-metadata-tree-vscode",
  "displayName": "CDT 41 (Community Development Tools for 1C)",
  "description": "Community Development Tools for 1C: visualize and edit 1C:Enterprise configuration metadata tree (EDT & Designer XML).",
  "version": "0.45.0",
  "icon": "images/icon.png",
  "publisher": "1c-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/lekot/VScodePluginFor1CDev"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "bsl",
        "aliases": [
          "1C (BSL)"
        ],
        "extensions": [
          ".bsl",
          ".os"
        ],
        "configuration": "./syntaxes/bsl-language-configuration.json"
      },
      {
        "id": "sdbl",
        "aliases": [
          "1C (SDBL)"
        ],
        "extensions": [
          ".sdbl",
          ".query"
        ],
        "configuration": "./syntaxes/sdbl-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bsl",
        "scopeName": "source.bsl",
        "path": "./syntaxes/1c.tmLanguage.json"
      },
      {
        "language": "sdbl",
        "scopeName": "source.sdbl",
        "path": "./syntaxes/1c-query.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "1c-metadata-tree.openPanel",
        "title": "CDT 41: Открыть дерево метаданных",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openIbcmdCheckReport",
        "title": "CDT 41: Открыть последний отчёт ibcmd check",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openIbcmdImportReport",
        "title": "CDT 41: Открыть последний отчёт ibcmd import",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.focus",
        "title": "Перейти к CDT 41",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.refresh",
        "title": "Обновить",
        "category": "CDT 41",
        "icon": "$(refresh)"
      },
      {
        "command": "1c-metadata-tree.showProperties",
        "title": "Свойства",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openXML",
        "title": "Открыть XML",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openBslModule",
        "title": "Открыть модуль BSL",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.createElement",
        "title": "Создать элемент",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.duplicateElement",
        "title": "Дублировать элемент",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.deleteElement",
        "title": "Удалить элемент",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.renameElement",
        "title": "Переименовать элемент",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.copyPathOrName",
        "title": "Копировать путь / имя",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.focusSearch",
        "title": "Поиск по дереву",
        "category": "CDT 41",
        "icon": "$(search)"
      },
      {
        "command": "1c-metadata-tree.clearSearch",
        "title": "Очистить поиск и фильтры",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.filterByType",
        "title": "Фильтр по типу метаданных",
        "category": "CDT 41",
        "icon": "$(filter)"
      },
      {
        "command": "1c-metadata-tree.nextMatch",
        "title": "Следующий результат",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.previousMatch",
        "title": "Предыдущий результат",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.clearCache",
        "title": "Очистить кэш дерева",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.exportLogs",
        "title": "Экспорт логов",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.copyDiagnosticsSummary",
        "title": "Копировать диагностику",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openFormEditor",
        "title": "Открыть в редакторе форм",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openRightsEditor",
        "title": "Открыть редактор прав",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openTemplatePreview",
        "title": "Открыть preview макета",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.saveRightsEditor",
        "title": "Сохранить права (редактор)",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.createForm",
        "title": "Создать форму",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.filterBySubsystem",
        "title": "Фильтр по подсистеме",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.clearSubsystemFilter",
        "title": "Сбросить фильтр подсистемы",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.addToSubsystemComposition",
        "title": "Добавить объект в состав подсистемы",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.removeFromSubsystemComposition",
        "title": "Удалить объект из состава подсистемы",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.editSubsystemComposition",
        "title": "Редактор состава подсистемы",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.editExchangePlanContent",
        "title": "Редактор состава плана обмена",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.editCommonAttributeContent",
        "title": "Редактор состава общего реквизита",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.editFunctionalOptionContent",
        "title": "Редактор состава функциональной опции",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.editFilterCriterionContent",
        "title": "CDT 41: Редактировать состав критерия отбора"
      },
      {
        "command": "1c-metadata-tree.infobaseManager.showIbcmdSetup",
        "title": "CDT 41: Настройка ibcmd…",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.infobases.refresh",
        "title": "Менеджер ИБ: обновить список",
        "category": "CDT 41",
        "icon": "$(refresh)"
      },
      {
        "command": "1c-metadata-tree.infobases.create",
        "title": "Менеджер ИБ: создать базу",
        "category": "CDT 41",
        "icon": "$(add)"
      },
      {
        "command": "1c-metadata-tree.infobases.add",
        "title": "Менеджер ИБ: добавить существующую",
        "category": "CDT 41",
        "icon": "$(folder-opened)"
      },
      {
        "command": "1c-metadata-tree.infobases.importV8i",
        "title": "Менеджер ИБ: импорт из .v8i",
        "category": "CDT 41",
        "icon": "$(file)"
      },
      {
        "command": "1c-metadata-tree.infobases.exportV8i",
        "title": "Менеджер ИБ: экспорт в .v8i",
        "category": "CDT 41",
        "icon": "$(export)"
      },
      {
        "command": "1c-metadata-tree.infobases.newFolder",
        "title": "Менеджер ИБ: новая папка",
        "category": "CDT 41",
        "icon": "$(new-folder)"
      },
      {
        "command": "1c-metadata-tree.infobase.openEnterprise",
        "title": "Открыть в 1С:Предприятие",
        "category": "CDT 41",
        "icon": "$(play)"
      },
      {
        "command": "1c-metadata-tree.infobase.openDesigner",
        "title": "Открыть Конфигуратор",
        "category": "CDT 41",
        "icon": "$(tools)"
      },
      {
        "command": "1c-metadata-tree.infobase.configImport",
        "title": "Загрузить конфигурацию…",
        "category": "CDT 41",
        "icon": "$(cloud-download)"
      },
      {
        "command": "1c-metadata-tree.infobase.configExport",
        "title": "Выгрузить конфигурацию…",
        "category": "CDT 41",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "1c-metadata-tree.infobase.configCheck",
        "title": "Проверить конфигурацию",
        "category": "CDT 41",
        "icon": "$(checklist)"
      },
      {
        "command": "1c-metadata-tree.infobase.compareConfig",
        "title": "Сравнить конфигурацию с другой базой…",
        "category": "CDT 41",
        "icon": "$(diff)"
      },
      {
        "command": "1c-metadata-tree.infobase.setCredentials",
        "title": "Настроить учётные данные…",
        "category": "CDT 41",
        "icon": "$(key)"
      },
      {
        "command": "1c-metadata-tree.infobase.moveToFolder",
        "title": "Переместить в папку…",
        "category": "CDT 41",
        "icon": "$(folder)"
      },
      {
        "command": "1c-metadata-tree.infobase.deleteFolder",
        "title": "Удалить папку",
        "category": "CDT 41",
        "icon": "$(trash)"
      },
      {
        "command": "1c-metadata-tree.infobase.renameFolder",
        "title": "Переименовать папку…",
        "category": "CDT 41",
        "icon": "$(edit)"
      },
      {
        "command": "1c-metadata-tree.infobase.edit",
        "title": "Редактировать…",
        "category": "CDT 41",
        "icon": "$(edit)"
      },
      {
        "command": "1c-metadata-tree.infobase.remove",
        "title": "Удалить из списка",
        "category": "CDT 41",
        "icon": "$(trash)"
      },
      {
        "command": "1c-metadata-tree.bindings.openDialog",
        "title": "Менеджер ИБ: привязка баз к конфигурации…",
        "category": "CDT 41",
        "icon": "$(link)"
      },
      {
        "command": "1c-metadata-tree.bindings.openDialogForConfiguration",
        "title": "Привязать базы…",
        "category": "CDT 41",
        "icon": "$(link)"
      },
      {
        "command": "1c-metadata-tree.config.deploy",
        "title": "Раскатать в базу…",
        "category": "CDT 41",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "1c-metadata-tree.config.deployMultiple",
        "title": "Раскатать в базы…",
        "category": "CDT 41",
        "icon": "$(run-all)"
      },
      {
        "command": "1c-metadata-tree.validateCurrentXml",
        "title": "CDT 41: Проверить XML (ibcmd preflight)",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.borrowToExtension",
        "title": "Добавить в расширение",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.navigateToMainObject",
        "title": "Перейти к объекту конфигурации",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.showRelatedObjects",
        "title": "Связанные объекты",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.showInterceptors",
        "title": "Показать перехваты",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.startDebugging",
        "title": "Запустить отладку",
        "category": "CDT 41",
        "icon": "$(debug-alt)"
      },
      {
        "command": "1c-metadata-tree.config.deploySelectedObjects",
        "title": "Раскатка выбранных в ИБ",
        "category": "CDT 41",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "1c-metadata-tree.config.pullSelectedObjects",
        "title": "Выгрузить выбранные из ИБ",
        "category": "CDT 41",
        "icon": "$(cloud-download)"
      },
      {
        "command": "1c-metadata-tree.config.deployChangedFiles",
        "title": "Раскатка изменённых файлов (git)",
        "category": "CDT 41",
        "icon": "$(git-commit)"
      },
      {
        "command": "1c-metadata-tree.config.configExportStatus",
        "title": "Статус конфигурации (ИБ vs файлы)",
        "category": "CDT 41",
        "icon": "$(diff)"
      },
      {
        "command": "1c-metadata-tree.getYaml",
        "title": "Показать YAML",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.agent.createObject",
        "title": "Agent: Создать объект метаданных",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.getYaml",
        "title": "Agent: Получить YAML объекта",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.listObjects",
        "title": "Agent: Список объектов конфигурации",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.getProperties",
        "title": "Agent: Получить свойства объекта",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.addAttribute",
        "title": "Agent: Добавить реквизит",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.addTabularSection",
        "title": "Agent: Добавить табличную часть",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.addTabularSectionColumn",
        "title": "Agent: Добавить колонку табличной части",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.deleteAttribute",
        "title": "Agent: Удалить реквизит или колонку ТЧ",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.deleteTabularSection",
        "title": "Agent: Удалить табличную часть",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.deleteObject",
        "title": "Agent: Удалить объект метаданных",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.renameObject",
        "title": "Agent: Переименовать объект метаданных",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.setProperties",
        "title": "Agent: Установить свойства объекта",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.getType",
        "title": "Agent: Получить тип объекта",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.setType",
        "title": "Agent: Установить тип объекта",
        "category": "CDT 41 Agent"
      },
      {
        "command": "1c-metadata-tree.agent.deploySelectedObjects",
        "title": "Agent: Раскатка выбранных файлов",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.agent.deployChangedFiles",
        "title": "Agent: Раскатка изменённых файлов (git)",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.agent.pullSelectedObjects",
        "title": "Agent: Выгрузить объекты из ИБ",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.agent.exportStatus",
        "title": "Agent: Статус конфигурации",
        "category": "CDT 41"
      }
    ],
    "customEditors": [
      {
        "viewType": "1c-form-editor",
        "displayName": "Редактор формы 1С",
        "selector": [
          {
            "filenamePattern": "**/Ext/Form.xml"
          }
        ]
      },
      {
        "viewType": "1c-mxl-preview",
        "displayName": "Preview макета MXL",
        "priority": "option",
        "selector": [
          {
            "filenamePattern": "**/Ext/Template.mxl"
          },
          {
            "filenamePattern": "**/Ext/Template.xml"
          },
          {
            "filenamePattern": "**/Ext/CommonTemplate.mxl"
          },
          {
            "filenamePattern": "**/Ext/CommonTemplate.xml"
          }
        ]
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "1c-metadata-tree.bindings.openDialogForConfiguration",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.config.deploy",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.config.deployMultiple",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.config.deploySelectedObjects",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.config.pullSelectedObjects",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.config.deployChangedFiles",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.config.configExportStatus",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.agent.deploySelectedObjects",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.agent.deployChangedFiles",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.agent.pullSelectedObjects",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.agent.exportStatus",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "1c-metadata-tree.refresh",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.focusSearch",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.clearSearch",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.infobases.refresh",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@1"
        },
        {
          "command": "1c-metadata-tree.infobases.create",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@2"
        },
        {
          "command": "1c-metadata-tree.infobases.add",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@3"
        },
        {
          "command": "1c-metadata-tree.infobases.importV8i",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@4"
        },
        {
          "command": "1c-metadata-tree.infobases.exportV8i",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@5"
        },
        {
          "command": "1c-metadata-tree.infobases.newFolder",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@6"
        }
      ],
      "editor/title": [
        {
          "command": "1c-metadata-tree.validateCurrentXml",
          "when": "resourceExtname == .xml",
          "group": "navigation@20"
        }
      ],
      "editor/context": [
        {
          "command": "1c-metadata-tree.validateCurrentXml",
          "when": "resourceExtname == .xml",
          "group": "navigation@20"
        }
      ],
      "view/item/context": [
        {
          "command": "1c-metadata-tree.bindings.openDialogForConfiguration",
          "when": "view == 1c-metadata-tree && viewItem =~ /^Configuration/",
          "group": "infobase@0"
        },
        {
          "command": "1c-metadata-tree.bindings.openDialogForConfiguration",
          "when": "view == 1c-metadata-tree && viewItem =~ /Extension extensionBindingRoot/",
          "group": "infobase@0"
        },
        {
          "command": "1c-metadata-tree.config.deploy",
          "when": "view == 1c-metadata-tree && viewItem =~ /Configuration.*bindingBound.*deployOne/",
          "group": "infobase@1"
        },
        {
          "command": "1c-metadata-tree.config.deploy",
          "when": "view == 1c-metadata-tree && viewItem =~ /Extension extensionBindingRoot.*bindingBound.*deployOne/",
          "group": "infobase@1"
        },
        {
          "command": "1c-metadata-tree.config.deployMultiple",
          "when": "view == 1c-metadata-tree && viewItem =~ /Configuration.*bindingBound.*deployMany/",
          "group": "infobase@1"
        },
        {
          "command": "1c-metadata-tree.config.deployMultiple",
          "when": "view == 1c-metadata-tree && viewItem =~ /Extension extensionBindingRoot.*bindingBound.*deployMany/",
          "group": "infobase@1"
        },
        {
          "command": "1c-metadata-tree.validateCurrentXml",
          "when": "view == 1c-metadata-tree && viewItem =~ /^Configuration/",
          "group": "infobase@2"
        },
        {
          "command": "1c-metadata-tree.validateCurrentXml",
          "when": "view == 1c-metadata-tree && viewItem =~ /Extension extensionBindingRoot/",
          "group": "infobase@2"
        },
        {
          "command": "1c-metadata-tree.config.deploySelectedObjects",
          "when": "view == 1c-metadata-tree && viewItem =~ /bindingBound/",
          "group": "infobase@2"
        },
        {
          "command": "1c-metadata-tree.config.pullSelectedObjects",
          "when": "view == 1c-metadata-tree && viewItem =~ /bindingBound/",
          "group": "infobase@2"
        },
        {
          "command": "1c-metadata-tree.config.deployChangedFiles",
          "when": "view == 1c-metadata-tree && viewItem =~ /bindingBound/",
          "group": "infobase@3"
        },
        {
          "command": "1c-metadata-tree.config.configExportStatus",
          "when": "view == 1c-metadata-tree && viewItem =~ /Configuration.*bindingBound/",
          "group": "infobase@4"
        },
        {
          "command": "1c-metadata-tree.startDebugging",

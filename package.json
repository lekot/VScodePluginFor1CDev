{
  "name": "1c-metadata-tree-vscode",
  "displayName": "1C Metadata Tree",
  "description": "VS Code extension for visualizing 1C configuration metadata tree",
  "version": "0.5.5",
  "publisher": "1c-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/1c-dev/1c-metadata-tree-vscode"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "1c-metadata-tree.openPanel",
        "title": "1C: Open Metadata Tree",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.refresh",
        "title": "Refresh",
        "category": "1C Metadata",
        "icon": "$(refresh)"
      },
      {
        "command": "1c-metadata-tree.showProperties",
        "title": "Show Properties",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.openXML",
        "title": "Open XML File",
        "category": "1C Metadata"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "1c-metadata-tree.openXML",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "1c-metadata-tree",
          "name": "1C Metadata",
          "when": "1c-metadata-tree:enabled"
        }
      ]
    },
    "keybindings": [
      {
        "command": "1c-metadata-tree.openPanel",
        "key": "ctrl+alt+1",
        "mac": "cmd+alt+1"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "tsc -p tsconfig.test.json && node node_modules/mocha/bin/mocha --ui tdd out/test/suite/*.test.js",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.0.0",
    "fast-check": "^4.6.0",
    "glob": "^10.0.0",
    "mocha": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.0"
  }
}
        "language": "bsl"
      }
    ],
    "debuggers": [
      {
        "type": "bsl",
        "label": "1C BSL Debugger",
        "languages": [
          "bsl"
        ],
        "configurationAttributes": {
          "attach": {
            "properties": {
              "host": {
                "type": "string",
                "description": "Debug server hostname",
                "default": "localhost"
              },
              "port": {
                "type": "number",
                "description": "Debug server port",
                "default": 1550
              },
              "infobaseAlias": {
                "type": "string",
                "description": "Infobase alias filter"
              },
              "autoAttachTargets": {
                "type": "boolean",
                "description": "Auto-attach to all debug targets",
                "default": true
              },
              "pingIntervalMs": {
                "type": "number",
                "description": "Event polling interval (ms)",
                "default": 1000
              },
              "connectTimeoutMs": {
                "type": "number",
                "description": "HTTP request timeout (ms)",
                "default": 5000
              }
            }
          },
          "launch": {
            "required": [
              "rootProject",
              "infobase"
            ],
            "properties": {
              "rootProject": {
                "type": "string",
                "description": "Путь к корню выгруженной конфигурации 1С"
              },
              "infobase": {
                "type": "string",
                "description": "Имя информационной базы или строка соединения"
              },
              "platformPath": {
                "type": "string",
                "description": "Каталог установки 1С (если не указан — discover)",
                "default": ""
              },
              "platformVersion": {
                "type": "string",
                "description": "Версия платформы 1С (если установлено несколько)",
                "default": ""
              },
              "debugServerHost": {
                "type": "string",
                "description": "Хост сервера отладки",
                "default": "localhost"
              },
              "debugServerPort": {
                "type": "number",
                "description": "Порт сервера отладки",
                "default": 1550
              },
              "extensions": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Пути к корням расширений конфигурации",
                "default": []
              },
              "autoAttachTypes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Типы автоподключения: Client, Server, WebClient и др.",
                "default": [
                  "Client",
                  "Server"
                ]
              },
              "infobaseAlias": {
                "type": "string",
                "description": "Псевдоним информационной базы для фильтрации",
                "default": ""
              },
              "pingIntervalMs": {
                "type": "number",
                "description": "Интервал опроса событий (мс)",
                "default": 1000
              },
              "connectTimeoutMs": {
                "type": "number",
                "description": "Таймаут HTTP-запросов (мс), 0 — без таймаута",
                "default": 0
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "bsl",
            "request": "attach",
            "name": "Attach to 1C",
            "host": "localhost",
            "port": 1550
          },
          {
            "type": "bsl",
            "request": "launch",
            "name": "Запуск 1С с отладчиком",
            "rootProject": "${workspaceFolder}",
            "infobase": "MyBase",
            "platformPath": "",
            "debugServerHost": "localhost",
            "debugServerPort": 1550
          }
        ],
        "configurationSnippets": [
          {
            "label": "BSL: Attach to 1C Debug Server",
            "description": "Attach to a running 1C:Enterprise debug server",
            "body": {
              "type": "bsl",
              "request": "attach",
              "name": "Attach to 1C",
              "host": "localhost",
              "port": 1550
            }
          },
          {
            "label": "BSL: Launch 1C with Debugger",
            "description": "Launch 1C:Enterprise client with integrated debug server",
            "body": {
              "type": "bsl",
              "request": "launch",
              "name": "Запуск 1С с отладчиком",
              "rootProject": "${workspaceFolder}",
              "infobase": "MyBase",
              "platformPath": "",
              "debugServerHost": "localhost",
              "debugServerPort": 1550
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile && node node_modules/@vscode/vsce/vsce package",
    "copy:webviews": "node scripts/copy-webviews.js",
    "compile": "tsc -p ./ && node scripts/copy-webviews.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "lint:test-promises": "eslint --no-eslintrc -c .eslintrc.test-promises.json test/runCore.ts test/runTest.ts test/runSmoke.ts test/suite/index.ts test/suite/smoke/index.ts test/suite/fixtureMatrix.test.ts --max-warnings 0",
    "lint:ci": "eslint src --ext ts --max-warnings 0",
    "verify": "npm run lint:ci && npm run lint:test-promises && npm run test:ci",
    "test": "tsc -p tsconfig.test.json && node -e \"require('fs').cpSync('test/fixtures','out/test/fixtures',{recursive:true,force:true})\" && node node_modules/mocha/bin/mocha --ui tdd out/test/suite/*.test.js",
    "copy:test-fixtures": "node -e \"require('fs').cpSync('test/fixtures','out/test/fixtures',{recursive:true,force:true})\"",
    "test:ci": "tsc -p tsconfig.test.json && npm run copy:test-fixtures && node scripts/copy-webviews.js && node out/test/runCore.js",
    "test:vscode:ci": "npm run compile && node node_modules/typescript/bin/tsc -p tsconfig.test.json && npm run copy:test-fixtures && node scripts/copy-webviews.js && xvfb-run -a node out/test/runTest.js",
    "test:coverage": "tsc -p tsconfig.test.json && npm run copy:test-fixtures && node scripts/copy-webviews.js && c8 --reporter=text-summary --reporter=json-summary node out/test/runCore.js",
    "coverage:check": "node scripts/check-coverage-delta.js",
    "test:smoke": "npm run compile && node node_modules/typescript/bin/tsc -p tsconfig.test.json && node out/test/runSmoke.js",
    "acceptance:epic36:block6": "node scripts/epic36-block6-acceptance.cjs",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.7.1",
    "c8": "^11.0.0",
    "eslint": "^8.0.0",
    "fast-check": "^4.6.0",
    "glob": "^10.0.0",
    "mocha": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@vscode/debugadapter": "^1.68.0",
    "fast-xml-parser": "^4.3.0",
    "iconv-lite": "^0.6.3",
    "js-yaml": "^4.1.1"
  },
  "c8": {
    "include": [
      "out/src/**/*.js"
    ]
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "arrowParens": "always"
  }

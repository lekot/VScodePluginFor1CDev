{
  "name": "1c-metadata-tree-vscode",
  "displayName": "1C Metadata Tree",
  "description": "VS Code extension for visualizing 1C configuration metadata tree",
  "version": "0.12.2",
  "icon": "images/icon.png",
  "publisher": "1c-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/1c-dev/1c-metadata-tree-vscode"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "1c-metadata-tree.openPanel",
        "title": "1C: Open Metadata Tree",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.focus",
        "title": "Focus 1C Metadata Tree",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.refresh",
        "title": "Refresh",
        "category": "1C Metadata",
        "icon": "$(refresh)"
      },
      {
        "command": "1c-metadata-tree.showProperties",
        "title": "Show Properties",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.openXML",
        "title": "Open XML File",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.createElement",
        "title": "Create Element",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.duplicateElement",
        "title": "Duplicate Element",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.deleteElement",
        "title": "Delete Element",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.renameElement",
        "title": "Rename Element",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.copyPathOrName",
        "title": "Copy Path / Name",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.focusSearch",
        "title": "Search in tree",
        "category": "1C Metadata",
        "icon": "$(search)"
      },
      {
        "command": "1c-metadata-tree.clearSearch",
        "title": "Clear search and filters",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.filterByType",
        "title": "Filter by metadata type",
        "category": "1C Metadata",
        "icon": "$(filter)"
      },
      {
        "command": "1c-metadata-tree.nextMatch",
        "title": "Next search result",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.previousMatch",
        "title": "Previous search result",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.clearCache",
        "title": "Clear tree cache",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.exportLogs",
        "title": "Export logs",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.openFormEditor",
        "title": "Открыть в редакторе форм",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.openRightsEditor",
        "title": "Open Rights Editor",
        "category": "1C Metadata"
      },
      {
        "command": "1c-metadata-tree.createForm",
        "title": "Создать форму",
        "category": "1C Metadata"
      }
    ],
    "customEditors": [
      {
        "viewType": "1c-form-editor",
        "displayName": "Редактор формы 1С",
        "selector": [
          {
            "filenamePattern": "**/Ext/Form.xml"
          }
        ]
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "1c-metadata-tree.refresh",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.focusSearch",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.clearSearch",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "1c-metadata-tree.openXML",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.showProperties",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.openFormEditor",
          "when": "view == 1c-metadata-tree && viewItem == 'Form'",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.openRightsEditor",
          "when": "view == 1c-metadata-tree && viewItem == 'Role'",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.createElement",
          "when": "view == 1c-metadata-tree",
          "group": "1_modify"
        },
        {
          "command": "1c-metadata-tree.createForm",
          "when": "view == 1c-metadata-tree && viewItem == 'Forms'",
          "group": "1_modify"
        },
        {
          "command": "1c-metadata-tree.duplicateElement",
          "when": "view == 1c-metadata-tree && viewItem != 'Configuration'",
          "group": "1_modify"
        },
        {
          "command": "1c-metadata-tree.deleteElement",
          "when": "view == 1c-metadata-tree && viewItem != 'Configuration'",
          "group": "1_modify"
        },
        {
          "command": "1c-metadata-tree.renameElement",
          "when": "view == 1c-metadata-tree && viewItem != 'Configuration'",
          "group": "1_modify"
        },
        {
          "command": "1c-metadata-tree.copyPathOrName",
          "when": "view == 1c-metadata-tree",
          "group": "3_copy"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "1c-metadata-tree",
          "name": "1C Metadata",
          "when": "1c-metadata-tree:enabled"
        }
      ]
    },
    "keybindings": [
      {
        "command": "1c-metadata-tree.openPanel",
        "key": "ctrl+alt+1",
        "mac": "cmd+alt+1"
      },
      {
        "command": "1c-metadata-tree.openPanel",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "view == 1c-metadata-tree"
      },
      {
        "command": "1c-metadata-tree.copyPathOrName",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "view == 1c-metadata-tree"
      },
      {
        "command": "1c-metadata-tree.duplicateElement",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "view == 1c-metadata-tree"
      },
      {
        "command": "1c-metadata-tree.deleteElement",
        "key": "Delete",
        "when": "view == 1c-metadata-tree"
      },
      {
        "command": "1c-metadata-tree.renameElement",
        "key": "f2",
        "when": "view == 1c-metadata-tree"
      },
      {
        "command": "1c-metadata-tree.focusSearch",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "view == 1c-metadata-tree"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile && node node_modules/@vscode/vsce/vsce package",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "tsc -p tsconfig.test.json && node node_modules/mocha/bin/mocha --ui tdd out/test/suite/*.test.js",
    "test:smoke": "npm run compile && node node_modules/typescript/bin/tsc -p tsconfig.test.json && node out/test/runSmoke.js",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.0.0",
    "fast-check": "^4.6.0",
    "glob": "^10.0.0",
    "mocha": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.0"
  }
}
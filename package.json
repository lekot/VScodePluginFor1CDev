{
  "name": "1c-metadata-tree-vscode",
  "displayName": "CDT 41 (Community Development Tools for 1C)",
  "description": "Community Development Tools for 1C: visualize and edit 1C:Enterprise configuration metadata tree (EDT & Designer XML).",
  "version": "0.34.0",
  "icon": "images/icon.png",
  "publisher": "1c-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/lekot/VScodePluginFor1CDev"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "1c-metadata-tree.openPanel",
        "title": "CDT 41: Open Metadata Tree",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openIbcmdCheckReport",
        "title": "CDT 41: Open last ibcmd check report",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openIbcmdImportReport",
        "title": "CDT 41: Open last ibcmd import report",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.focus",
        "title": "Focus CDT 41",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.refresh",
        "title": "Refresh",
        "category": "CDT 41",
        "icon": "$(refresh)"
      },
      {
        "command": "1c-metadata-tree.showProperties",
        "title": "Show Properties",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openXML",
        "title": "Open XML File",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openBslModule",
        "title": "Открыть модуль BSL",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.createElement",
        "title": "Create Element",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.duplicateElement",
        "title": "Duplicate Element",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.deleteElement",
        "title": "Delete Element",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.renameElement",
        "title": "Rename Element",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.copyPathOrName",
        "title": "Copy Path / Name",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.focusSearch",
        "title": "Search in tree",
        "category": "CDT 41",
        "icon": "$(search)"
      },
      {
        "command": "1c-metadata-tree.clearSearch",
        "title": "Clear search and filters",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.filterByType",
        "title": "Filter by metadata type",
        "category": "CDT 41",
        "icon": "$(filter)"
      },
      {
        "command": "1c-metadata-tree.nextMatch",
        "title": "Next search result",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.previousMatch",
        "title": "Previous search result",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.clearCache",
        "title": "Clear tree cache",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.exportLogs",
        "title": "Export logs",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.copyDiagnosticsSummary",
        "title": "Copy diagnostics summary",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openFormEditor",
        "title": "Открыть в редакторе форм",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openRightsEditor",
        "title": "Open Rights Editor",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.openTemplatePreview",
        "title": "Открыть preview макета",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.saveRightsEditor",
        "title": "Save Rights (Editor)",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.createForm",
        "title": "Создать форму",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.filterBySubsystem",
        "title": "Filter by Subsystem",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.clearSubsystemFilter",
        "title": "Clear Subsystem Filter",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.addToSubsystemComposition",
        "title": "Добавить объект в состав подсистемы",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.removeFromSubsystemComposition",
        "title": "Удалить объект из состава подсистемы",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.editSubsystemComposition",
        "title": "Редактор состава подсистемы",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.infobaseManager.showIbcmdSetup",
        "title": "CDT 41: Configure ibcmd…",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.infobases.refresh",
        "title": "Infobase Manager: обновить список",
        "category": "CDT 41",
        "icon": "$(refresh)"
      },
      {
        "command": "1c-metadata-tree.infobases.create",
        "title": "Infobase Manager: создать базу",
        "category": "CDT 41",
        "icon": "$(add)"
      },
      {
        "command": "1c-metadata-tree.infobases.add",
        "title": "Infobase Manager: добавить существующую",
        "category": "CDT 41",
        "icon": "$(folder-opened)"
      },
      {
        "command": "1c-metadata-tree.infobases.importV8i",
        "title": "Infobase Manager: импорт из .v8i",
        "category": "CDT 41",
        "icon": "$(file)"
      },
      {
        "command": "1c-metadata-tree.infobases.exportV8i",
        "title": "Infobase Manager: экспорт в .v8i",
        "category": "CDT 41",
        "icon": "$(export)"
      },
      {
        "command": "1c-metadata-tree.infobases.newFolder",
        "title": "Infobase Manager: новая папка",
        "category": "CDT 41",
        "icon": "$(new-folder)"
      },
      {
        "command": "1c-metadata-tree.infobase.openEnterprise",
        "title": "Открыть в 1С:Предприятие",
        "category": "CDT 41",
        "icon": "$(play)"
      },
      {
        "command": "1c-metadata-tree.infobase.openDesigner",
        "title": "Открыть Конфигуратор",
        "category": "CDT 41",
        "icon": "$(tools)"
      },
      {
        "command": "1c-metadata-tree.infobase.configImport",
        "title": "Загрузить конфигурацию…",
        "category": "CDT 41",
        "icon": "$(cloud-download)"
      },
      {
        "command": "1c-metadata-tree.infobase.configExport",
        "title": "Выгрузить конфигурацию…",
        "category": "CDT 41",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "1c-metadata-tree.infobase.configCheck",
        "title": "Проверить конфигурацию",
        "category": "CDT 41",
        "icon": "$(checklist)"
      },
      {
        "command": "1c-metadata-tree.infobase.compareConfig",
        "title": "Сравнить конфигурацию с другой базой…",
        "category": "CDT 41",
        "icon": "$(diff)"
      },
      {
        "command": "1c-metadata-tree.infobase.setCredentials",
        "title": "Настроить учётные данные…",
        "category": "CDT 41",
        "icon": "$(key)"
      },
      {
        "command": "1c-metadata-tree.infobase.moveToFolder",
        "title": "Переместить в папку…",
        "category": "CDT 41",
        "icon": "$(folder)"
      },
      {
        "command": "1c-metadata-tree.infobase.deleteFolder",
        "title": "Удалить папку",
        "category": "CDT 41",
        "icon": "$(trash)"
      },
      {
        "command": "1c-metadata-tree.infobase.renameFolder",
        "title": "Переименовать папку…",
        "category": "CDT 41",
        "icon": "$(edit)"
      },
      {
        "command": "1c-metadata-tree.infobase.edit",
        "title": "Редактировать…",
        "category": "CDT 41",
        "icon": "$(edit)"
      },
      {
        "command": "1c-metadata-tree.infobase.remove",
        "title": "Удалить из списка",
        "category": "CDT 41",
        "icon": "$(trash)"
      },
      {
        "command": "1c-metadata-tree.bindings.openDialog",
        "title": "Infobase Manager: привязка баз к конфигурации…",
        "category": "CDT 41",
        "icon": "$(link)"
      },
      {
        "command": "1c-metadata-tree.bindings.openDialogForConfiguration",
        "title": "Привязать базы…",
        "category": "CDT 41",
        "icon": "$(link)"
      },
      {
        "command": "1c-metadata-tree.config.deploy",
        "title": "Раскатать в базу…",
        "category": "CDT 41",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "1c-metadata-tree.config.deployMultiple",
        "title": "Раскатать в базы…",
        "category": "CDT 41",
        "icon": "$(run-all)"
      },
      {
        "command": "1c-metadata-tree.validateCurrentXml",
        "title": "CDT 41: Validate current XML (ibcmd preflight)",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.borrowToExtension",
        "title": "Добавить в расширение",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.navigateToMainObject",
        "title": "Перейти к объекту конфигурации",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.showRelatedObjects",
        "title": "Связанные объекты",
        "category": "CDT 41"
      },
      {
        "command": "1c-metadata-tree.showInterceptors",
        "title": "Показать перехваты",
        "category": "CDT 41"
      }
    ],
    "customEditors": [
      {
        "viewType": "1c-form-editor",
        "displayName": "Редактор формы 1С",
        "selector": [
          {
            "filenamePattern": "**/Ext/Form.xml"
          }
        ]
      },
      {
        "viewType": "1c-mxl-preview",
        "displayName": "Preview макета MXL",
        "priority": "option",
        "selector": [
          {
            "filenamePattern": "**/Ext/Template.mxl"
          },
          {
            "filenamePattern": "**/Ext/Template.xml"
          },
          {
            "filenamePattern": "**/Ext/CommonTemplate.mxl"
          },
          {
            "filenamePattern": "**/Ext/CommonTemplate.xml"
          }
        ]
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "1c-metadata-tree.bindings.openDialogForConfiguration",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.config.deploy",
          "when": "false"
        },
        {
          "command": "1c-metadata-tree.config.deployMultiple",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "1c-metadata-tree.refresh",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.focusSearch",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.clearSearch",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.infobases.refresh",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@1"
        },
        {
          "command": "1c-metadata-tree.infobases.create",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@2"
        },
        {
          "command": "1c-metadata-tree.infobases.add",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@3"
        },
        {
          "command": "1c-metadata-tree.infobases.importV8i",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@4"
        },
        {
          "command": "1c-metadata-tree.infobases.exportV8i",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@5"
        },
        {
          "command": "1c-metadata-tree.infobases.newFolder",
          "when": "view == 1c-infobase-manager",
          "group": "navigation@6"
        }
      ],
      "editor/title": [
        {
          "command": "1c-metadata-tree.validateCurrentXml",
          "when": "resourceExtname == .xml",
          "group": "navigation@20"
        }
      ],
      "editor/context": [
        {
          "command": "1c-metadata-tree.validateCurrentXml",
          "when": "resourceExtname == .xml",
          "group": "navigation@20"
        }
      ],
      "view/item/context": [
        {
          "command": "1c-metadata-tree.bindings.openDialogForConfiguration",
          "when": "view == 1c-metadata-tree && viewItem =~ /^Configuration/",
          "group": "infobase@0"
        },
        {
          "command": "1c-metadata-tree.bindings.openDialogForConfiguration",
          "when": "view == 1c-metadata-tree && viewItem =~ /Extension extensionBindingRoot/",
          "group": "infobase@0"
        },
        {
          "command": "1c-metadata-tree.config.deploy",
          "when": "view == 1c-metadata-tree && viewItem =~ /Configuration.*bindingBound.*deployOne/",
          "group": "infobase@1"
        },
        {
          "command": "1c-metadata-tree.config.deploy",
          "when": "view == 1c-metadata-tree && viewItem =~ /Extension extensionBindingRoot.*bindingBound.*deployOne/",
          "group": "infobase@1"
        },
        {
          "command": "1c-metadata-tree.config.deployMultiple",
          "when": "view == 1c-metadata-tree && viewItem =~ /Configuration.*bindingBound.*deployMany/",
          "group": "infobase@1"
        },
        {
          "command": "1c-metadata-tree.config.deployMultiple",
          "when": "view == 1c-metadata-tree && viewItem =~ /Extension extensionBindingRoot.*bindingBound.*deployMany/",
          "group": "infobase@1"
        },
        {
          "command": "1c-metadata-tree.validateCurrentXml",
          "when": "view == 1c-metadata-tree && viewItem =~ /^Configuration/",
          "group": "infobase@2"
        },
        {
          "command": "1c-metadata-tree.validateCurrentXml",
          "when": "view == 1c-metadata-tree && viewItem =~ /Extension extensionBindingRoot/",
          "group": "infobase@2"
        },
        {
          "command": "1c-metadata-tree.openXML",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.openBslModule",
          "when": "view == 1c-metadata-tree && viewItem == 'MethodBsl'",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.showProperties",
          "when": "view == 1c-metadata-tree",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.openFormEditor",
          "when": "view == 1c-metadata-tree && viewItem == 'Form'",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.openRightsEditor",
          "when": "view == 1c-metadata-tree && viewItem == 'Role'",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.openTemplatePreview",
          "when": "view == 1c-metadata-tree && viewItem == 'Template'",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.openTemplatePreview",
          "when": "view == 1c-metadata-tree && viewItem == 'CommonTemplate'",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.createElement",
          "when": "view == 1c-metadata-tree",
          "group": "1_modify"
        },
        {
          "command": "1c-metadata-tree.createForm",
          "when": "view == 1c-metadata-tree && viewItem == 'Forms'",
          "group": "1_modify"
        },
        {
          "command": "1c-metadata-tree.duplicateElement",
          "when": "view == 1c-metadata-tree && viewItem != 'Configuration'",
          "group": "1_modify"
        },
        {
          "command": "1c-metadata-tree.deleteElement",
          "when": "view == 1c-metadata-tree && viewItem != 'Configuration'",
          "group": "1_modify"
        },
        {
          "command": "1c-metadata-tree.renameElement",
          "when": "view == 1c-metadata-tree && viewItem != 'Configuration'",
          "group": "1_modify"
        },
        {
          "command": "1c-metadata-tree.copyPathOrName",
          "when": "view == 1c-metadata-tree",
          "group": "3_copy"
        },
        {
          "command": "1c-metadata-tree.filterBySubsystem",
          "when": "view == 1c-metadata-tree && viewItem == 'Subsystem'",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.editSubsystemComposition",
          "when": "view == 1c-metadata-tree && viewItem =~ /Subsystem/",
          "group": "2_subsystem@0"
        },
        {
          "command": "1c-metadata-tree.clearSubsystemFilter",
          "when": "view == 1c-metadata-tree && subsystemFilterActive",
          "group": "navigation"
        },
        {
          "command": "1c-metadata-tree.infobase.openEnterprise",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server|Web)$/",
          "group": "inline@1"
        },
        {
          "command": "1c-metadata-tree.infobase.openDesigner",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server)$/",
          "group": "inline@2"
        },
        {
          "command": "1c-metadata-tree.infobase.configImport",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server)$/",
          "group": "inline@3"
        },
        {
          "command": "1c-metadata-tree.infobase.configExport",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server)$/",
          "group": "inline@4"
        },
        {
          "command": "1c-metadata-tree.infobase.openEnterprise",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server|Web)$/",
          "group": "infobase@1"
        },
        {
          "command": "1c-metadata-tree.infobase.openDesigner",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server)$/",
          "group": "infobase@2"
        },
        {
          "command": "1c-metadata-tree.infobase.configImport",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server)$/",
          "group": "infobase@3"
        },
        {
          "command": "1c-metadata-tree.infobase.configExport",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server)$/",
          "group": "infobase@4"
        },
        {
          "command": "1c-metadata-tree.infobase.configCheck",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server)$/",
          "group": "infobase@5"
        },
        {
          "command": "1c-metadata-tree.infobase.compareConfig",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server)$/",
          "group": "infobase@5b"
        },
        {
          "command": "1c-metadata-tree.infobase.setCredentials",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server|Web)$/",
          "group": "infobase@5b2"
        },
        {
          "command": "1c-metadata-tree.infobase.moveToFolder",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server|Web)$/",
          "group": "infobase@5c"
        },
        {
          "command": "1c-metadata-tree.infobase.edit",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server|Web)$/",
          "group": "infobase@6"
        },
        {
          "command": "1c-metadata-tree.infobase.remove",
          "when": "view == 1c-infobase-manager && viewItem =~ /^infobase(File|Server|Web)$/",
          "group": "infobase@7"
        },
        {
          "command": "1c-metadata-tree.infobases.newFolder",
          "when": "view == 1c-infobase-manager && viewItem == 'infobaseFoldersRoot'",
          "group": "infobaseFolder@1"
        },
        {
          "command": "1c-metadata-tree.infobases.newFolder",
          "when": "view == 1c-infobase-manager && viewItem == 'infobaseFolder'",
          "group": "infobaseFolder@1"
        },
        {
          "command": "1c-metadata-tree.infobase.renameFolder",
          "when": "view == 1c-infobase-manager && viewItem == 'infobaseFolder'",
          "group": "infobaseFolder@2"
        },
        {
          "command": "1c-metadata-tree.infobase.deleteFolder",
          "when": "view == 1c-infobase-manager && viewItem == 'infobaseFolder'",
          "group": "infobaseFolder@3"
        },
        {
          "command": "1c-metadata-tree.borrowToExtension",
          "when": "view == 1c-metadata-tree && viewItem =~ /^(Catalog|Document|Enum|Report|DataProcessor|InformationRegister|AccumulationRegister|CommonModule|Role|Subsystem|CommonForm|CommonTemplate|CommonPicture|CommonCommand|ExchangePlan|Constant|ChartOfCharacteristicTypes|ChartOfAccounts|AccountingRegister|ChartOfCalculationTypes|CalculationRegister|BusinessProcess|Task|DocumentJournal|FilterCriterion|SettingsStorage|FunctionalOption|ScheduledJob)$/",
          "group": "3_extension@0"
        },
        {
          "command": "1c-metadata-tree.navigateToMainObject",
          "when": "view == 1c-metadata-tree && viewItem =~ /\\.Adopted$/",
          "group": "3_extension@1"
        },
        {
          "command": "1c-metadata-tree.showRelatedObjects",
          "when": "view == 1c-metadata-tree",
          "group": "3_extension@2"
        },
        {
          "command": "1c-metadata-tree.showInterceptors",
          "when": "view == 1c-metadata-tree && viewItem =~ /MethodBsl/",
          "group": "3_extension@3"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "1c-metadata-tree",
          "name": "CDT 41",
          "when": "1c-metadata-tree:enabled"
        },
        {
          "id": "1c-infobase-manager",
          "name": "Infobase Manager",
          "when": "1c-metadata-tree:enabled"
        }
      ]
    },
    "configuration": {
      "title": "CDT 41",
      "properties": {
        "1cMetadataTree.rightsEditor.compactRightsWrite": {
          "type": "boolean",
          "default": true,
          "description": "Use compact rights write in Rights Editor: only output <right> when true for simple rights; keep and update only <value> for rights with restrictionByCondition."
        },
        "1cMetadataTree.ibcmd.path": {
          "type": "string",
          "default": "",
          "description": "Path to the ibcmd executable (WOW Infobase Manager). When empty, IBCMD_PATH or auto-detect is used (same as matrix / e2e)."
        },
        "1cMetadataTree.platform.path": {
          "type": "string",
          "default": "",
          "description": "Directory containing 1cv8.exe, full path to 1cv8.exe / 1cv8c.exe, or empty for auto-detect (standard install dirs and PATH)."
        },
        "1cMetadataTree.ibcmd.timeout": {
          "type": "number",
          "default": 600,
          "description": "Timeout in seconds for ibcmd operations. Zero or negative values fall back to IBCMD_TIMEOUT_MS (ms) or built-in default (600 s)."
        },
        "1cMetadataTree.ibcmd.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "When true and path/env are empty, search PATH and typical 1cv8 install directories for ibcmd."
        },
        "1cMetadataTree.ibcmd.consoleOutputEncoding": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "utf8",
            "utf16le",
            "oem866",
            "windows1251"
          ],
          "description": "How to decode ibcmd stdout/stderr for the Infobase output channel. \"auto\" uses UTF-8 streaming (typical piped ibcmd [INFO] lines). If text is garbled, try \"oem866\" (legacy Russian console) or \"windows1251\". For UTF-16 LE output, use \"utf16le\"."
        },
        "1cMetadataTree.ibcmd.importDiagnostics": {
          "type": "boolean",
          "default": false,
          "description": "Log ibcmd config import diagnostics to \"CDT 41: Infobase (ibcmd)\": --config path, redacted YAML body (target infobase), and configuration dump directory passed as the last CLI argument (not stored in YAML). Use when debugging deploy / YAML path issues."
        },
        "1cMetadataTree.git.reloadMetadataOnHeadChange": {
          "type": "boolean",
          "default": true,
          "description": "WOW Phase 4: when the built-in Git extension reports a new HEAD commit in a workspace repository, reload the CDT 41 metadata tree (useful after git pull or checkout)."
        },
        "1cMetadataTree.git.refreshInfobaseManagerOnHeadChange": {
          "type": "boolean",
          "default": true,
          "description": "WOW Phase 4: when Git HEAD changes in a workspace repository, refresh the Infobase Manager tree and binding decorations (e.g. after pull when .vscode/infobase-bindings.json changed)."
        },
        "1cMetadataTree.deploy.mode": {
          "type": "string",
          "default": "copy",
          "enum": [
            "copy",
            "block"
          ],
          "description": "Deploy mode (WOW Phase 2): copy — from project copy; block — lock editors."
        },
        "1cMetadataTree.deploy.precheckXmlBeforeImport": {
          "type": "boolean",
          "default": false,
          "description": "Run XML preflight (ibcmd config import check phase) before deploy import into linked infobase; when enabled and preflight fails, deploy stops."
        }
      }
    },
    "keybindings": [
      {
        "command": "1c-metadata-tree.openPanel",
        "key": "ctrl+alt+1",
        "mac": "cmd+alt+1"
      },
      {
        "command": "1c-metadata-tree.openPanel",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "view == 1c-metadata-tree"
      },
      {
        "command": "1c-metadata-tree.copyPathOrName",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "view == 1c-metadata-tree"
      },
      {
        "command": "1c-metadata-tree.duplicateElement",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "view == 1c-metadata-tree"
      },
      {
        "command": "1c-metadata-tree.deleteElement",
        "key": "Delete",
        "when": "view == 1c-metadata-tree"
      },
      {
        "command": "1c-metadata-tree.renameElement",
        "key": "f2",
        "when": "view == 1c-metadata-tree"
      },
      {
        "command": "1c-metadata-tree.focusSearch",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "view == 1c-metadata-tree"
      },
      {
        "command": "1c-metadata-tree.saveRightsEditor",
        "key": "ctrl+s",
        "mac": "cmd+s",
        "when": "activeWebviewPanelId == '1c-rights-editor'"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile && node node_modules/@vscode/vsce/vsce package",
    "copy:webviews": "node scripts/copy-webviews.js",
    "compile": "tsc -p ./ && node scripts/copy-webviews.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "lint:test-promises": "eslint --no-eslintrc -c .eslintrc.test-promises.json test/runCore.ts test/runTest.ts test/runSmoke.ts test/suite/index.ts test/suite/smoke/index.ts test/suite/fixtureMatrix.test.ts --max-warnings 0",
    "lint:ci": "eslint src --ext ts --max-warnings 0",
    "verify": "npm run lint:ci && npm run lint:test-promises && npm run test:ci",
    "test": "tsc -p tsconfig.test.json && node -e \"require('fs').cpSync('test/fixtures','out/test/fixtures',{recursive:true,force:true})\" && node node_modules/mocha/bin/mocha --ui tdd out/test/suite/*.test.js",
    "copy:test-fixtures": "node -e \"require('fs').cpSync('test/fixtures','out/test/fixtures',{recursive:true,force:true})\"",
    "test:ci": "tsc -p tsconfig.test.json && npm run copy:test-fixtures && node scripts/copy-webviews.js && node out/test/runCore.js",
    "test:vscode:ci": "npm run compile && node node_modules/typescript/bin/tsc -p tsconfig.test.json && npm run copy:test-fixtures && node scripts/copy-webviews.js && xvfb-run -a node out/test/runTest.js",
    "test:coverage": "tsc -p tsconfig.test.json && npm run copy:test-fixtures && node scripts/copy-webviews.js && c8 --reporter=text-summary --reporter=json-summary node out/test/runCore.js",
    "coverage:check": "node scripts/check-coverage-delta.js",
    "test:smoke": "npm run compile && node node_modules/typescript/bin/tsc -p tsconfig.test.json && node out/test/runSmoke.js",
    "acceptance:epic36:block6": "node scripts/epic36-block6-acceptance.cjs",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.7.1",
    "c8": "^11.0.0",
    "eslint": "^8.0.0",
    "fast-check": "^4.6.0",
    "glob": "^10.0.0",
    "mocha": "^10.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "fast-xml-parser": "^4.3.0",
    "iconv-lite": "^0.6.3"
  },
  "c8": {
    "include": [
      "out/src/**/*.js"
    ]
  }
}
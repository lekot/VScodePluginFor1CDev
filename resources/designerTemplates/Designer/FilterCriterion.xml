<?xml version='1.0' encoding='utf-8'?>
<!-- Критерий отбора: для ibcmd/config import нужны непустой Content (xr:Item) и cfg:-типы в Type; шаблон — заготовка до настройки в конфигураторе. Матрица e2e не создаёт FilterCriterion (см. matrixTargetPredicate). -->
<MetaDataObject xmlns="http://v8.1c.ru/8.3/MDClasses" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:xr="http://v8.1c.ru/8.3/xcf/readable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <FilterCriterion uuid="{uuid}">
    <Properties>
      <AuxiliaryForm />
      <Comment />
      <Content />
      <DefaultForm />
      <Explanation />
      <ExtendedListPresentation />
      <ListPresentation />
      <Name>{Name}</Name>
      <Synonym>
        <v8:item>
          <v8:lang>ru</v8:lang>
          <v8:content>{Synonym_ru}</v8:content>
        </v8:item>
      </Synonym>
      <Type>
        <v8:Type>xs:string</v8:Type>
        <v8:StringQualifiers>
          <v8:Length>10</v8:Length>
          <v8:AllowedLength>Variable</v8:AllowedLength>
        </v8:StringQualifiers>
      </Type>
      <UseStandardCommands>false</UseStandardCommands>
    </Properties>
    <ChildObjects />
  </FilterCriterion>
</MetaDataObject>
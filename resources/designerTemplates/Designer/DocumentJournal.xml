<?xml version='1.0' encoding='utf-8'?>
<MetaDataObject xmlns="http://v8.1c.ru/8.3/MDClasses" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:xr="http://v8.1c.ru/8.3/xcf/readable" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <DocumentJournal uuid="{uuid}">
    <Properties>
      <AuxiliaryForm />
      <Comment />
      <DefaultForm />
      <Explanation />
      <ExtendedListPresentation />
      <ListPresentation />
      <Name>{Name}</Name>
      <RegisteredDocuments>
        <xr:Item xsi:type="xr:MDObjectRef">{RecorderDocumentRef}</xr:Item>
      </RegisteredDocuments>
      <Synonym>
        <v8:item>
          <v8:lang>ru</v8:lang>
          <v8:content>{Synonym_ru}</v8:content>
        </v8:item>
      </Synonym>
      <UseStandardCommands>true</UseStandardCommands>
    </Properties>
    <ChildObjects />
  </DocumentJournal>
</MetaDataObject>

{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile-direct",
      "type": "shell",
      "command": "node",
      "args": ["node_modules/typescript/bin/tsc", "-p", "."],
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "npm: compile",
      "type": "shell",
      "command": "npm",
      "args": ["run", "compile"],
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "npm: watch",
      "type": "shell",
      "command": "npm",
      "args": ["run", "watch"],
      "isBackground": true,
      "problemMatcher": "$tsc-watch"
    },
    {
      "label": "CDT: ibcmd — check infobase configuration",
      "type": "shell",
      "command": "node",
      "args": ["scripts/ibcmd-cli.cjs", "check"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CDT: ibcmd — import configuration from XML",
      "type": "shell",
      "command": "node",
      "args": ["scripts/ibcmd-cli.cjs", "import"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
